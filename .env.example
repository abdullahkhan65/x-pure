# ---- Postgres (used directly by docker-compose and by DATABASE_URL below) ----
POSTGRES_USER=xpure
POSTGRES_PASSWORD=xpure_dev_password
POSTGRES_DB=xpure
POSTGRES_PORT=5432
DATABASE_URL=postgresql://xpure:xpure_dev_password@localhost:5432/xpure?schema=public

# ---- Redis ----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---- API ----
NODE_ENV=development
API_PORT=3001
CORS_ORIGIN=http://localhost:3000
JWT_ACCESS_SECRET=change-me-access-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
COOKIE_DOMAIN=localhost

# ---- Seed ----
SEED_ADMIN_EMAIL=admin@xpure.dev
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_DEMO_DATA=true

# ---- Admin (Next.js) ----
NEXT_PUBLIC_APP_NAME="X-Pure Water Delivery"
API_ORIGIN=http://localhost:3001
