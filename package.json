{
  "name": "x-pure",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "prepare": "husky",
    "db:generate": "turbo run db:generate --filter=@x-pure/database",
    "db:migrate": "turbo run db:migrate --filter=@x-pure/database",
    "db:migrate:deploy": "turbo run db:migrate:deploy --filter=@x-pure/database",
    "db:seed": "turbo run db:seed --filter=@x-pure/database",
    "db:studio": "turbo run db:studio --filter=@x-pure/database"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
